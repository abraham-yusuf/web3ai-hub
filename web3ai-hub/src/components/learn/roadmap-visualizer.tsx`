"use client";

import React from "react";
import { Card, CardContent } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { Button } from "@/components/ui/button";
import { BookOpen, CheckCircle2, Clock, ChevronRight, Target } from "lucide-react";
import Link from "next/link";

interface Step {
  id: string;
  title: string;
  description: string;
  order: number;
  type: string;
  pageSlug: string | null;
  estimatedTime?: string | null;
  milestone?: string | null;
  isCompleted: boolean;
}

interface RoadmapVisualizerProps {
  steps: Step[];
  onToggleComplete?: (id: string) => Promise<void>;
}

export function RoadmapVisualizer({ steps, onToggleComplete }: RoadmapVisualizerProps) {
  // Group steps by milestone
  const milestones = Array.from(
    new Map(
      steps
        .sort((a, b) => a.order - b.order)
        .map((step) => [step.milestone || "General", step])
    ).values()
  ).map((group) => group.sort((a, b) => a.order - b.order));

  // Actual unique milestones list
  const milestoneNames = Array.from(new Set(steps.map((s) => s.milestone || "General")));

  return (
    <div className="relative space-y-12 py-8">
      {milestoneNames.map((mName, mIndex) => {
        const mSteps = steps.filter((s) => (s.milestone || "General") === mName);
        
        return (
          <div key={mName} className="relative space-y-6">
            {/* Milestone Header */}
            <div className="flex items-center gap-4 mb-8">
              <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary text-primary-foreground font-bold shadow-lg shadow-primary/20">
                {mIndex + 1}
              </div>
              <div className="flex-1 h-px bg-muted-foreground/20" />
              <h3 className="text-xl font-bold tracking-tight flex items-center gap-2">
                <Target className="h-5 w-5 text-primary" /> {mName}
              </h3>
            </div>

            {/* Steps in this milestone */}
            <div className="grid gap-4 pl-12 sm:pl-16">
              {mSteps.sort((a, b) => a.order - b.order).map((step) => (
                <div key={step.id} className="relative group">
                  <Card className={`transition-all duration-300 ${step.isCompleted ? "bg-muted/50 border-primary/20" : "hover:border-primary/50"}`}>
                    <CardContent className="p-4 flex items-center justify-between gap-4">
                      <div className="flex items-start gap-4">
                        <div className={`mt-1 p-2 rounded-lg ${step.type === "content" ? "bg-blue-100 text-blue-600" : "bg-green-100 text-green-600"}`}>
                          {step.type === "content" ? <BookOpen className="h-4 w-4" /> : <CheckCircle2 className="h-4 w-4" />}
                        </div>
                        <div className="space-y-1">
                          <div className="flex items-center gap-2">
                            <h4 className={`font-semibold ${step.isCompleted ? "line-through text-muted-foreground" : ""}`}>
                              {step.title}
                            </h4>
                            {step.estimatedTime && (
                              <Badge variant="outline" className="text-[10px] gap-1 font-normal">
                                <Clock className="h-3 w-3" /> {step.estimatedTime}
                              </Badge>
                            )}
                          </div>
                          <p className="text-sm text-muted-foreground line-clamp-1">{step.description}</p>
                        </div>
                      </div>

                      <div className="flex items-center gap-2">
                        {step.pageSlug ? (
                          <Button size="sm" asChild variant="outline" className="gap-2">
                            <Link href={`/learn/${step.pageSlug}`}>
                              Learn <ChevronRight className="h-3 w-3" />
                            </Link>
                          </Button>
                        ) : (
                          <Button 
                            size="sm" 
                            variant={step.isCompleted ? "secondary" : "default"}
                            onClick={() => onToggleComplete?.(step.id)}
                          >
                            {step.isCompleted ? "Completed" : "Mark Done"}
                          </Button>
                        )}
                      </div>
                    </CardContent>
                  </Card>
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  );
}
