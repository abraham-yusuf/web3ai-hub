# ===============================================
# Web3AI Hub — Environment Variables
# ================================================
# Copy to .env.local for development: cp .env.example .env.local
#
# Modes:
#   development — local dev, requires DATABASE_URL + NEXTAUTH_SECRET
#   staging     — preview/UAT, same external services as production
#   production  — live, all secrets via deploy platform (e.g. Vercel)
#   test        — unit/integration tests, DATABASE_URL optional
# ================================================

# Runtime mode
NODE_ENV="development"

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/web3ai_hub"

# ---- Auth ----
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap admin (initial setup only — change before staging/production!)
ADMIN_EMAIL="admin@web3aihub.com"
ADMIN_PASSWORD="change-me-now"

# ---- AI Providers (at least one required for AI features) ----
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
GROQ_API_KEY=""

# Encryption key for storing AI API keys in DB (base64 32-byte)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_SETTINGS_ENCRYPTION_KEY=""

# ---- Monetization ----
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXX"

# ---- Storage (Cloudflare R2) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# ---- Analytics (Umami) ----
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_URL="https://umami.example.com"

# ---- Email (Resend) ----
RESEND_API_KEY=""

# ---- App URL (for sitemap, OG, canonical) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
