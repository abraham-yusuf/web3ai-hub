# ===============================================
# Web3AI Hub — Environment Variables
# ================================================
# Copy to .env.local for development: cp .env.example .env.local
#
# Modes:
#   development — local dev, requires DATABASE_URL + NEXTAUTH_SECRET
#   staging     — preview/UAT, same external services as production
#   production  — live, all secrets via deploy platform (e.g. Vercel)
#   test        — unit/integration tests, DATABASE_URL optional
# ================================================

# Runtime mode
NODE_ENV="development"

# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5432/web3ai_hub"
# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://user:password@localhost:5432/web3ai_hub"

# ---- Auth ----
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap admin (initial setup only — change before staging/production!)
ADMIN_EMAIL="admin@web3aihub.com"
ADMIN_PASSWORD="change-me-now"

# ---- AI Providers (at least one required for AI features) ----
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
GROQ_API_KEY=""

# Encryption key for storing AI API keys in DB (base64 32-byte)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AI_SETTINGS_ENCRYPTION_KEY=""

# ---- Monetization ----
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXX"

# ---- Storage (Cloudflare R2) ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# ---- Analytics ----
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_URL="https://umami.example.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GSC_VERIFICATION="google-site-verification-token"

# ---- Email (Resend) ----
RESEND_API_KEY=

# ---- Discord ----
# Discord webhook URL for announcements (create in Discord channel settings > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=
# Discord bot token (if using bot commands) - requires intents: Guilds, GuildMessages
DISCORD_BOT_TOKEN=

# ---- Telegram ----
# Create bot via @BotFather and get the token
TELEGRAM_BOT_TOKEN=
# Your admin Telegram chat ID (for testing) - get via @userinfobot
TELEGRAM_ADMIN_CHAT_ID=
# Telegram channel ID for announcements (e.g., -1001234567890 for channels)
TELEGRAM_ANNOUNCEMENTS_CHANNEL_ID=

# ---- App URL (for sitemap, OG, canonical) ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis (caching)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Webhooks
WEBHOOK_SECRET=
CRON_SECRET=
