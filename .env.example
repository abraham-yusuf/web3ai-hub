# Runtime mode
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/web3ai_hub"

# NextAuth
NEXTAUTH_SECRET="replace-with-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap admin credentials (for initial setup only)
ADMIN_EMAIL="admin@web3aihub.com"
ADMIN_PASSWORD="change-me-now"

# AI Providers (minimal satu)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
GROQ_API_KEY=""

# Encryption key (base64 32-byte untuk menyimpan AI key terenkripsi)
AI_SETTINGS_ENCRYPTION_KEY=""
# AdSense
NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-XXXXXXXXXX"

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""

# Analytics (Umami)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_URL="https://umami.example.com"
