generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  username      String?         @unique
  name          String?
  email         String?         @unique
  password      String?
  image         String?
  bio           String?
  twitter       String?
  github        String?
  linkedin      String?
  telegram      String?
  role          Role            @default(VIEWER)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  learnProgress LearnProgress[]
  posts         Post[]
  roadmaps      UserRoadmap[]
  approvedPosts Post[]          @relation("PostApprovedBy")
  rejectedPosts Post[]          @relation("PostRejectedBy")
  revisions     PostRevision[]
  coAuthoredPosts PostCoAuthor[]
}

model UserRoadmap {
  id        String        @id @default(cuid())
  userId    String
  title     String
  goal      String
  level     String
  status    String        @default("active")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  steps     RoadmapStep[]
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RoadmapStep {
  id          String      @id @default(cuid())
  roadmapId   String
  title       String
  description String
  order       Int         @default(0)
  isCompleted Boolean     @default(false)
  type        String      @default("content")
  pageSlug    String?
  estimatedTime String?   // e.g., "2 days", "1 week"
  milestone   String?     // e.g., "Foundations", "Advanced Integration"
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  roadmap     UserRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
}

model Post {
  id           String    @id @default(cuid())
  title        String
  slug         String    @unique
  content      String
  excerpt      String?
  coverImage   String?
  category     String
  tags         String[]
  published    Boolean   @default(false)  // Legacy toggle — use status for workflow
  featured     Boolean   @default(false)
  publishedAt  DateTime?
  scheduledFor DateTime?

  // ── Content Workflow ──────────────────────────────
  status       PostStatus @default(DRAFT)
  version      Int        @default(1)      // Auto-increment on each save
  viewCount    Int        @default(0)      // Reading analytics
  readTimeMinutes Int?    @default(0)      // Estimated reading time (minutes)

  // Review / Approval
  submittedForReviewAt DateTime?
  reviewedAt           DateTime?
  reviewerNotes        String?             // Feedback from editor/reviewer
  approvedById         String?
  rejectedById         String?

  // Multi-author
  authorId     String
  coAuthors    PostCoAuthor[]
  revisions    PostRevision[]

  // Timestamps
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  author       User      @relation(fields: [authorId], references: [id])
  approvedBy   User?     @relation("PostApprovedBy", fields: [approvedById], references: [id])
  rejectedBy   User?     @relation("PostRejectedBy", fields: [rejectedById], references: [id])

  @@index([slug])
  @@index([category])
  @@index([status])
}

// Tracks every content revision for history / rollback
model PostRevision {
  id        String   @id @default(cuid())
  postId    String
  version   Int
  title     String
  content   String
  excerpt   String?
  authorId  String   // Who made this revision
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@unique([postId, version])
  @@index([postId])
}

// Multi-author support (PRIMARY author + co-authors)
model PostCoAuthor {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  role      String   @default("CONTRIBUTOR") // PRIMARY | CO_AUTHOR | CONTRIBUTOR
  addedAt   DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Airdrop {
  id              String        @id @default(cuid())
  name            String
  slug            String        @unique
  logo            String?
  network         String
  status          AirdropStatus @default(ACTIVE)
  estimatedReward String?
  difficulty      Difficulty    @default(MEDIUM)
  deadline        DateTime?
  content         String
  steps           Json?
  requirements    String[]
  links           Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([slug])
  @@index([status])
}

model AITool {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  tagline       String?
  logo          String?
  description   String
  category      String
  pricing       String
  rating        Float            @default(0)
  affiliateLink String?
  featured      Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  clicks        AffiliateClick[]

  @@index([slug])
  @@index([category])
}

model AffiliateClick {
  id        String   @id @default(cuid())
  toolId    String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  tool      AITool   @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId, createdAt])
}

model LearnTrack {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?
  type        TrackType      @default(WEB3)
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sections    LearnSection[]

  @@index([slug])
}

model LearnSection {
  id        String      @id @default(cuid())
  title     String
  order     Int         @default(0)
  trackId   String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  pages     LearnPage[]
  track     LearnTrack  @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model LearnPage {
  id        String       @id @default(cuid())
  title     String
  slug      String       @unique
  content   String
  order     Int          @default(0)
  sectionId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  section   LearnSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([slug])
}

model LearnProgress {
  id        String   @id @default(cuid())
  userId    String
  pageSlug  String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pageSlug])
  @@index([pageSlug])
}

model Quiz {
  id        String     @id @default(cuid())
  title     String
  pageSlug  String     @unique
  questions Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Flashcard {
  id        String   @id @default(cuid())
  pageSlug  String
  front     String
  back      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageSlug])
}

model SiteSettings {
  id            String   @id @default("default")
  aiProviders   Json?
  adSenseConfig Json?
  updatedAt     DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum PostStatus {
  DRAFT       // Initial state, not submitted for review
  IN_REVIEW   // Submitted for editorial review
  APPROVED    // Approved, ready to publish (auto or manual)
  PUBLISHED   // Live on the site
}

enum AirdropStatus {
  ACTIVE
  UPCOMING
  ENDED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum TrackType {
  WEB3
  AI
}

model TopicCluster {
  id          String   @id @default(cuid())
  topic       String   @unique  // e.g. "Solana", "DeFi", "Smart Contracts"
  slug        String   @unique
  description String?
  keywords    String[] // SEO keywords for this topic
  pillarPages String[] // slugs of pillar (hub) pages
  relatedUrls Json?    // { blogSlugs: string[], learnSlugs: string[], airdropSlugs: string[] }
  searchVolume Int?    // estimated monthly searches
  difficulty  String?  // "easy" | "medium" | "hard"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([topic])
}

model SeoScore {
  id          String   @id @default(cuid())
  entityType  String   // "post" | "airdrop" | "tool" | "learn"
  entitySlug  String
  score       Int      @default(0)  // 0-100
  factors     Json?    // { title: int, meta: int, content: int, links: int, technical: int }
  checkedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([entityType, entitySlug])
  @@index([entityType])
}
